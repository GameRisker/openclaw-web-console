{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "调试 API (server.mjs)",
      "preLaunchTask": "释放 API 端口 (3001)",
      "program": "${workspaceFolder}/server.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Vite 开发服务器",
      "program": "${workspaceFolder}/../node_modules/vite/bin/vite.js",
      "args": [
        "./openclaw-web-client",
        "--config",
        "./openclaw-web-client/vite.config.ts"
      ],
      "cwd": "${workspaceFolder}/..",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Chrome：前端 (需先起 Vite)",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/../openclaw-web-client"
    }
  ],
  "compounds": [
    {
      "name": "全栈：API + Vite",
      "configurations": ["调试 API (server.mjs)", "Vite 开发服务器"],
      "stopAll": true,
      "presentation": {
        "group": "fullstack",
        "order": 1
      }
    }
  ]
}
