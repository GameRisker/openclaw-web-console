{
  "name": "openclaw-web-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite ./openclaw-web-client --config ./openclaw-web-client/vite.config.ts",
    "dev:api": "node ./openclaw-web-api/server.mjs",
    "build": "tsc -b ./openclaw-web-client/tsconfig.json && vite build ./openclaw-web-client --config ./openclaw-web-client/vite.config.ts",
    "start": "node ./openclaw-web-api/server.mjs",
    "typecheck": "tsc -b ./openclaw-web-client/tsconfig.json",
    "lint": "eslint -c ./openclaw-web-client/eslint.config.js \"./openclaw-web-client/**/*.{ts,tsx}\"",
    "preview": "vite preview ./openclaw-web-client --config ./openclaw-web-client/vite.config.ts"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.3.3",
    "express": "^5.2.1",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
